# MySQL 8.0 — Benchmark configuration for AxiomDB comparison
#
# Goal: maximum honest performance with full durability ON.
# All fsync-equivalent settings are enabled so comparisons with
# AxiomDB (which also runs with fsync=true) are apples-to-apples.
#
# To run a "no-durability" comparison (pure throughput ceiling),
# set innodb_flush_log_at_trx_commit=0 and sync_binlog=0.

[mysqld]

# ── Character set ────────────────────────────────────────────────────────────
character-set-server        = utf8mb4
collation-server            = utf8mb4_unicode_ci
character_set_client_handshake = OFF

# ── InnoDB storage engine ────────────────────────────────────────────────────
default_storage_engine      = InnoDB

# Buffer pool: ~50% of container RAM (2 GB limit → 1 GB pool)
innodb_buffer_pool_size     = 1G
innodb_buffer_pool_instances= 2

# Log file: larger = fewer checkpoints = better write throughput
innodb_log_file_size        = 256M
innodb_log_buffer_size      = 64M

# Durability: ON (same as AxiomDB fsync=true)
# 1 = fsync WAL + data on every COMMIT  ← honest comparison mode
# 0 = no fsync (throughput ceiling mode, change for pure speed test)
innodb_flush_log_at_trx_commit = 1

# Binlog sync: ON for full durability
# 1 = sync binlog on every COMMIT
# 0 = OS decides (comment out for pure speed test)
sync_binlog                 = 1

# I/O method: O_DIRECT bypasses OS double-buffering (same as AxiomDB mmap)
innodb_flush_method         = O_DIRECT

# Disable double-write buffer — AxiomDB doesn't use it; disable for fairer I/O comparison
# NOTE: without doublewrite, MySQL relies on innodb_checksum_algorithm for crash recovery
# innodb_doublewrite        = OFF   # uncomment to match AxiomDB's no-doublewrite design

# Thread concurrency: match CPU limit (2 cores)
innodb_thread_concurrency   = 4
innodb_read_io_threads      = 2
innodb_write_io_threads     = 2

# ── Connections ───────────────────────────────────────────────────────────────
max_connections             = 50
skip-name-resolve           = ON

# ── Query cache (disabled in MySQL 8, left explicit) ─────────────────────────
# query_cache_type          = 0  # already default in 8.0

# ── Networking ────────────────────────────────────────────────────────────────
max_allowed_packet          = 64M
net_buffer_length           = 16K

# ── Temp tables ───────────────────────────────────────────────────────────────
tmp_table_size              = 64M
max_heap_table_size         = 64M

# ── Binary log (minimal overhead for benchmarks) ─────────────────────────────
# Disable binlog entirely for benchmark purity (no replication overhead)
# Comment out if you want binlog-on comparison (closer to production MySQL)
skip-log-bin                = ON
