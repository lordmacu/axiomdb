{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo bench:*)",
      "Bash(cargo fuzz:*)",
      "Bash(cargo new:*)",
      "Bash(cargo add:*)",
      "Bash(cargo tree:*)",
      "Bash(cargo flamegraph:*)",
      "Bash(cargo install:*)",
      "Bash(cargo run:*)",
      "Bash(cargo check:*)",
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(mkdir -p:*)",
      "Bash(cat > docs/*)",
      "Bash(cat > specs/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/cristian/nexusdb/.claude/check-docs-before-commit.sh",
            "statusMessage": "Verificando docs antes de commit..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/cristian/nexusdb && [ -f Cargo.toml ] && cargo fmt 2>/dev/null; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/cristian/nexusdb && echo '\\n── Estado al parar ──' && git status --short || echo 'Repo no disponible'; exit 0"
          }
        ]
      }
    ]
  }
}
